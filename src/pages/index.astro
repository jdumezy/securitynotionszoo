---
import BaseLayout from "../layouts/BaseLayout.astro";
import RelationMap from "../components/RelationMap.astro";
import { getCollection } from "astro:content";

const allNotions = await getCollection("notions");
const allTags = Array.from(new Set(allNotions.flatMap((notion) => notion.data.tags))).sort();
---

<BaseLayout title="SecurityNotionsZoo | Cryptography Notions Taxonomy">
  <div class="mb-12">
    <h1
      class="text-4xl font-extrabold mb-4 text-slate-900 dark:text-slate-100 transition-colors"
    >
      Security Notions Taxonomy
    </h1>
    <p
      class="text-lg text-slate-600 dark:text-slate-400 text-justify transition-colors mb-4"
    >
      A taxonomy of cryptographic security notions, focusing on Fully
      Homomorphic Encryption (FHE).
    </p>
    <p
      class="text-lg text-slate-600 dark:text-slate-400 text-justify transition-colors"
    >
      Because most FHE constructions rely on lattices, interesting things happen
      due to ciphertext malleability and inherent noise. This has led to the
      definition of a wide variety of specialized attacks and security notions.
      The relationship map below illustrates this landscape of alternative
      security definitions tailored for FHE. Directed arrows indicate
      theoretical implications (<span class="font-serif italic">A</span> &rarr; <span
        class="font-serif italic">B</span
      > means <span class="font-serif italic">A</span> implies <span
        class="font-serif italic">B</span
      >, i.e. that <span class="font-serif italic">A</span> is (usually) a strictly
      stronger notion than <span class="font-serif italic">B</span>). Click on
      any notion in the graph or the list below for more information.
    </p>
    <p
      class="text-lg text-slate-600 dark:text-slate-400 text-justify transition-colors mt-4"
    >
      For more information on the different game variations, see the <a
        href="/flavors"
        class="text-sky-600 dark:text-accent hover:text-sky-500 dark:hover:text-sky-300 transition-colors"
        >flavors page</a
      >, which describes the differences between security games such as IND, KR,
      and others for the same security notion. If you are new to provable
      security, the <a
        href="/primer"
        class="text-sky-600 dark:text-accent hover:text-sky-500 dark:hover:text-sky-300 transition-colors"
        >security primer</a
      > introduces the core vocabulary: PPT adversaries, negligible functions,
      game-based definitions, reductions, and hybrid arguments.
    </p>
  </div>

  <section class="mb-16">
    <h2
      class="text-2xl font-semibold mb-6 text-slate-900 dark:text-slate-200 transition-colors"
    >
      Relation Map
    </h2>

    <div
      class="bg-slate-100 dark:bg-slate-800/30 p-2 md:p-6 rounded-2xl border border-slate-200 dark:border-slate-700/50 shadow-inner overflow-hidden transition-colors"
    >
      <RelationMap notions={allNotions} />
    </div>
  </section>

  <section>
    <div class="flex justify-between items-end mb-6">
      <h2
        class="text-2xl font-semibold text-slate-900 dark:text-slate-200 transition-colors"
      >
        All Notions (<span id="notions-count">{allNotions.length}</span>)
      </h2>
      <a
        href="/notions/all"
        class="text-sky-600 dark:text-accent hover:text-sky-500 dark:hover:text-sky-300 text-sm font-medium transition-colors decoration-transparent"
        >View Detailed List &rarr;</a
      >
    </div>

    <div class="flex flex-wrap gap-2 mb-8" id="tag-filters">
      <button class="filter-btn active px-3 py-1.5 text-sm font-medium rounded-md transition-colors bg-sky-600 text-white dark:bg-accent hover:opacity-90" data-tag="all">All</button>
      {
        allTags.map((tag) => (
          <button class="filter-btn px-3 py-1.5 text-sm font-medium rounded-md transition-colors bg-slate-200 text-slate-700 dark:bg-slate-800 dark:text-slate-300 hover:bg-slate-300 dark:hover:bg-slate-700" data-tag={tag}>{tag}</button>
        ))
      }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="notions-grid">
      {
        allNotions.map((notion) => (
          <a
            href={`/notions/${notion.slug}`}
            class="notion-card block group no-underline decoration-transparent"
            data-tags={notion.data.tags.join(',')}
          >
            <article class="h-full bg-white dark:bg-slate-800/20 rounded-xl p-6 border border-slate-200 dark:border-slate-700/50 hover:border-slate-400 dark:hover:border-slate-500 transition-all hover:bg-slate-50 dark:hover:bg-slate-800/80 hover:shadow-lg hover:-translate-y-1">
              <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 group-hover:text-sky-600 dark:group-hover:text-accent mb-2 transition-colors">
                {notion.data.acronym}
              </h3>
              <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-3 line-clamp-2 transition-colors">
                {notion.data.title}
              </p>
              <p class="text-sm text-slate-600 dark:text-slate-300 mb-4 line-clamp-3 transition-colors">
                {notion.data.description}
              </p>
              <div class="flex flex-wrap gap-2 mt-auto">
                {notion.data.tags.map((tag) => (
                  <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700/50 text-slate-600 dark:text-slate-300 rounded-md transition-colors">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </section>

  <script>
    function setupFilters() {
      const buttons = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.notion-card');
      const countEl = document.getElementById('notions-count');

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          buttons.forEach((b) => {
            b.classList.remove('active', 'bg-sky-600', 'text-white', 'dark:bg-accent', 'hover:opacity-90');
            b.classList.add('bg-slate-200', 'text-slate-700', 'dark:bg-slate-800', 'dark:text-slate-300', 'hover:bg-slate-300', 'dark:hover:bg-slate-700');
          });

          btn.classList.remove('bg-slate-200', 'text-slate-700', 'dark:bg-slate-800', 'dark:text-slate-300', 'hover:bg-slate-300', 'dark:hover:bg-slate-700');
          btn.classList.add('active', 'bg-sky-600', 'text-white', 'dark:bg-accent', 'hover:opacity-90');

          const selectedTag = btn.getAttribute('data-tag') || '';
          let visibleCount = 0;

          cards.forEach((card) => {
            const tags = card.getAttribute('data-tags')?.split(',') || [];
            if (selectedTag === 'all' || tags.includes(selectedTag)) {
              card.classList.remove('hidden');
              card.classList.add('block');
              visibleCount++;
            } else {
              card.classList.remove('block');
              card.classList.add('hidden');
            }
          });

          if (countEl) countEl.textContent = visibleCount.toString();
        });
      });
    }

    document.addEventListener('DOMContentLoaded', setupFilters);
    document.addEventListener('astro:page-load', setupFilters); // re-run after view transitions
  </script>
</BaseLayout>
