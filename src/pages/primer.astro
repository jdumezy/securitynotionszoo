---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Content } from "../content/primer.mdx";
import ReadProgressBar from "../components/ReadProgressBar.astro";
import BackToTop from "../components/BackToTop.astro";
import BackToTaxonomy from "../components/BackToTaxonomy.astro";
---

<BaseLayout
  title="Security Primer | SecurityNotionsZoo"
  description="An introduction to the key concepts behind security proofs: PPT adversaries, negligible functions, game-based definitions, reductions, and hybrid arguments."
>
  <div class="mb-10">
    <a href="/" class="text-sky-600 dark:text-accent hover:text-sky-500 dark:hover:text-sky-300 text-sm font-medium inline-flex items-center gap-1 mb-8 decoration-transparent transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Back to taxonomy
    </a>

    <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-slate-100 mb-3 tracking-tight transition-colors">
      Security Primer
    </h1>
    <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-400 font-medium max-w-3xl leading-snug transition-colors">
      Key concepts behind security definitions and proofs
    </p>
  </div>

  <div class="prose prose-slate dark:prose-invert prose-a:text-sky-600 dark:prose-a:text-accent hover:prose-a:text-sky-500 dark:hover:prose-a:text-sky-300 max-w-none prose-headings:text-slate-900 dark:prose-headings:text-slate-200 transition-colors text-justify">
    <Content />
  </div>

  <BackToTaxonomy />
  <ReadProgressBar />
  <BackToTop />
</BaseLayout>
