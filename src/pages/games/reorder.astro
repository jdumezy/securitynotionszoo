---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const notions = await getCollection("notions");

type Notion = (typeof notions)[number];
const byAcronym: Record<string, Notion> = Object.fromEntries(
  notions.map((n) => [n.data.acronym, n]),
);

// Transitive closure of the full implies graph, keyed by acronym
const closure: Record<string, Set<string>> = {};
for (const n of notions) {
  const seen = new Set<string>();
  const stack = [...n.data.implies];
  while (stack.length) {
    const a = stack.pop()!;
    if (seen.has(a)) continue;
    seen.add(a);
    const child = byAcronym[a];
    if (child) stack.push(...child.data.implies);
  }
  closure[n.data.acronym] = seen;
}

// Compute the ground-truth edges for a filtered acronym set:
// transitive reduction of (full closure ∩ filtered²)
function edgesForSubset(acronyms: string[]): [string, string][] {
  const filtered = new Set(acronyms);

  // Restricted closure: what each filtered notion implies within the filter
  const restricted: Record<string, Set<string>> = {};
  for (const a of acronyms) {
    restricted[a] = new Set(
      [...(closure[a] ?? [])].filter((b) => filtered.has(b)),
    );
  }

  // Transitive reduction: edge a→b iff b ∈ restricted[a] AND
  // there is no c ∈ acronyms with a→c→b in the restricted graph
  const edges: [string, string][] = [];
  for (const a of acronyms) {
    for (const b of restricted[a]) {
      let redundant = false;
      for (const c of acronyms) {
        if (c === a || c === b) continue;
        if (restricted[a].has(c) && restricted[c].has(b)) {
          redundant = true;
          break;
        }
      }
      if (!redundant) edges.push([a, b]);
    }
  }
  return edges;
}

const beginnerSet = ["CPA", "CCA1", "CCA2", "CPAD", "vCCA"];
const intermediateSet = [
  ...beginnerSet,
  "CCA1.5",
  "CCVA1",
  "CCVA2",
  "gCCA",
  "RCCA",
  "funcCPA",
];
const expertSet = notions.map((n) => n.data.acronym);

// Validate that every acronym in the beginner/intermediate sets actually exists
for (const a of [...beginnerSet, ...intermediateSet]) {
  if (!byAcronym[a]) {
    throw new Error(`Unknown acronym in difficulty set: ${a}`);
  }
}

type LevelPayload = {
  acronyms: string[];
  titles: Record<string, string>;
  slugs: Record<string, string>;
  edges: [string, string][]; // transitive reduction: the "essential" edges
  closureEdges: [string, string][]; // full closure: everything transitively implied
};

function closureForSubset(acronyms: string[]): [string, string][] {
  const filtered = new Set(acronyms);
  const out: [string, string][] = [];
  for (const a of acronyms) {
    for (const b of closure[a] ?? []) {
      if (filtered.has(b)) out.push([a, b]);
    }
  }
  return out;
}

function buildLevel(acronyms: string[]): LevelPayload {
  const titles: Record<string, string> = {};
  const slugs: Record<string, string> = {};
  for (const a of acronyms) {
    const n = byAcronym[a];
    titles[a] = n?.data.title ?? a;
    slugs[a] = n?.slug ?? "";
  }
  return {
    acronyms,
    titles,
    slugs,
    edges: edgesForSubset(acronyms),
    closureEdges: closureForSubset(acronyms),
  };
}

const gameData = {
  levels: {
    beginner: buildLevel(beginnerSet),
    intermediate: buildLevel(intermediateSet),
    expert: buildLevel(expertSet),
  },
};

const gameJson = JSON.stringify(gameData).replace(/</g, "\\u003c");
---

<BaseLayout
  title="Recreate the graph | SecurityNotionsZoo"
  description="Rebuild the implication graph of cryptographic security notions from scratch."
>
  <div class="mb-8">
    <a
      href="/games/"
      class="text-sky-600 dark:text-accent hover:text-sky-500 dark:hover:text-sky-300 text-sm font-medium inline-flex items-center gap-1 mb-6 decoration-transparent transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
      >
      Back to games
    </a>
  </div>

  <div class="max-w-2xl mx-auto w-full">
    <!-- START SCREEN -->
    <section id="rg-start" class="space-y-8">
      <div>
        <h1
          class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-slate-100 mb-3 tracking-tight transition-colors"
        >
          Recreate the graph
        </h1>
        <p
          class="text-lg text-slate-600 dark:text-slate-400 transition-colors"
        >
          Rebuild the implication graph by drawing arrows from stronger notions
          to weaker ones. The target is the minimum set of essential arrows:
          transitive shortcuts count as redundant but valid.
        </p>
      </div>

      <div
        class="bg-white dark:bg-slate-800/20 rounded-2xl p-6 md:p-8 border border-slate-200 dark:border-slate-700/50 shadow-sm transition-colors"
