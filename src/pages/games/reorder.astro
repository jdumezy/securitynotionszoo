            </button>
            <button
              type="button"
              data-difficulty="expert"
              class="rg-diff-btn py-4 px-4 rounded-xl font-semibold border-2 transition-colors text-left"
            >
              <div class="text-lg">Expert</div>
              <div class="text-xs mt-1 opacity-80">
