            </button>
          </div>
        </fieldset>

        <button
          type="button"
          id="rg-start-btn"
          class="w-full mt-6 py-4 px-6 rounded-xl bg-sky-600 dark:bg-accent text-white text-lg font-semibold hover:opacity-90 active:opacity-80 transition-opacity"
        >
          Start
        </button>

        <p
