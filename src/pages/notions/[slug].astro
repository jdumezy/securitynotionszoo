---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const notions = await getCollection('notions');
  return notions.map(notion => ({
    params: { slug: notion.slug },
    props: { notion },
  }));
}

const { notion } = Astro.props;
const { Content } = await notion.render();
---

<BaseLayout
  title={`${notion.data.acronym} - ${notion.data.title} | SecurityNotionsZoo`}
  description={notion.data.description}
  type="article"
  keywords={[notion.data.acronym, `IND-${notion.data.acronym}`, notion.data.title, ...notion.data.tags, 'FHE', 'Fully Homomorphic Encryption', 'cryptography', 'security notion']}
>
  <div class="mb-10">
    <a href="/" class="text-sky-600 dark:text-accent hover:text-sky-500 dark:hover:text-sky-300 text-sm font-medium inline-flex items-center gap-1 mb-8 decoration-transparent transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Back to taxonomy
    </a>
    
    <div class="flex flex-wrap gap-2 mb-5">
      {notion.data.tags.map((tag: string) => (
        <span class="px-2.5 py-1.5 text-xs font-semibold bg-sky-100 dark:bg-accent/10 text-sky-700 dark:text-accent rounded border border-sky-200 dark:border-accent/20 transition-colors">
          {tag}
        </span>
      ))}
    </div>
    
    <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-slate-100 mb-3 tracking-tight transition-colors">
      {notion.data.acronym}
    </h1>
    <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-400 font-medium max-w-3xl leading-snug transition-colors">
      {notion.data.title}
    </p>
  </div>

  {(notion.data.introduced_in && notion.data.introduced_in.filter((p: any) => p.title).length > 0) || (notion.data.implies.length > 0 || notion.data.implied_by.length > 0) ? (
    <div class="mb-10 grid grid-cols-1 lg:grid-cols-2 gap-6 items-stretch">
      {notion.data.introduced_in && notion.data.introduced_in.filter((p: any) => p.title).length > 0 && (
        <div class="bg-white dark:bg-slate-800/30 rounded-2xl p-6 border border-slate-200 dark:border-slate-700/50 transition-colors overflow-hidden">
          <h3 class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-4 transition-colors">Introduced In</h3>
          <ul class="space-y-5">
            {notion.data.introduced_in.filter((p: any) => p.title).map((paper: any) => (
              <li class="text-sm">
                {paper.link ? (
                  <a href={paper.link} target="_blank" rel="noopener noreferrer" class="font-semibold text-slate-800 dark:text-slate-200 hover:text-sky-600 dark:hover:text-accent block mb-1 transition-colors break-words">
                    {paper.title}
                  </a>
                ) : (
                  <span class="font-semibold text-slate-800 dark:text-slate-200 block mb-1 transition-colors break-words">
                    {paper.title}
                  </span>
                )}
                {((paper.authors && paper.authors.length > 0) || paper.year) && (
                  <p class="text-slate-600 dark:text-slate-400 block leading-relaxed transition-colors break-words">
                    {[paper.authors && paper.authors.join(', '), paper.year && `(${paper.year})`].filter(Boolean).join(' ')}
                  </p>
                )}
              </li>
            ))}
          </ul>
        </div>
      )}

      {(notion.data.implies.length > 0 || notion.data.implied_by.length > 0) && (
        <div class="bg-white dark:bg-slate-800/30 rounded-2xl p-6 border border-slate-200 dark:border-slate-700/50 transition-colors">
          <h3 class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-4 transition-colors">Relations</h3>

          <div class="flex flex-col sm:flex-row gap-6">
            {notion.data.implied_by.length > 0 && (
              <div class="flex-1">
                <h4 class="text-xs font-medium text-slate-600 dark:text-slate-500 mb-2 transition-colors">Implied By</h4>
                <div class="flex flex-wrap gap-2">
                  {notion.data.implied_by.map((rel: string) => (
                    <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700/60 text-slate-700 dark:text-slate-300 rounded border border-slate-200 dark:border-slate-600 transition-colors">
                      {rel}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {notion.data.implies.length > 0 && (
              <div class="flex-1">
                <h4 class="text-xs font-medium text-slate-600 dark:text-slate-500 mb-2 transition-colors">Implies</h4>
                <div class="flex flex-wrap gap-2">
                  {notion.data.implies.map((rel: string) => (
                    <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700/60 text-slate-700 dark:text-slate-300 rounded border border-slate-200 dark:border-slate-600 transition-colors">
                      {rel}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  ) : null}

  <div class="prose prose-slate dark:prose-invert prose-a:text-sky-600 dark:prose-a:text-accent hover:prose-a:text-sky-500 dark:hover:prose-a:text-sky-300 max-w-none prose-headings:text-slate-900 dark:prose-headings:text-slate-200 transition-colors text-justify">
    <Content />
  </div>
</BaseLayout>
