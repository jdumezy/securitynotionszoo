---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNotions = await getCollection('notions');
allNotions.sort((a, b) => a.data.acronym.localeCompare(b.data.acronym));

const renderedNotions = await Promise.all(
  allNotions.map(async (notion) => {
    const { Content } = await notion.render();
    return { notion, Content };
  })
);
---

<BaseLayout title="All Security Notions | SecurityNotionsZoo" description="A complete list of all cryptographic security notions." noindex={true}>
  <div class="mb-10">
    <a href="/" class="text-sky-600 dark:text-accent hover:text-sky-500 dark:hover:text-sky-300 text-sm font-medium inline-flex items-center gap-1 mb-8 decoration-transparent transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Back to taxonomy
    </a>
    <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-slate-100 mb-4 tracking-tight transition-colors">
      All Security Notions
    </h1>
    <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl transition-colors">
      Browse the complete dictionary of all cryptographic security games and definitions currently cataloged.
    </p>
  </div>

  <div class="mb-8">
    <div class="relative">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 pointer-events-none"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
      <input
        type="search"
        id="notion-search"
        placeholder="Filter by acronym, title, tag, or description…"
        aria-label="Filter notions on this page"
        class="w-full pl-12 pr-4 py-3 bg-white dark:bg-slate-800/20 border border-slate-200 dark:border-slate-700/50 rounded-xl text-slate-900 dark:text-slate-100 placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-sky-500 dark:focus:border-accent focus:ring-2 focus:ring-sky-500/20 dark:focus:ring-accent/20 transition-colors"
      />
    </div>
    <p class="mt-3 text-sm text-slate-500 dark:text-slate-400 transition-colors flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <span>
        Showing <span id="search-count">{renderedNotions.length}</span> of {renderedNotions.length} notions
      </span>
      <span class="text-xs opacity-70">Filters this page only. Use <kbd class="px-1 py-0.5 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded text-[10px] font-mono">⌘K</kbd> for site-wide search.</span>
    </p>
    <p id="search-empty" class="mt-6 text-center text-slate-500 dark:text-slate-400 hidden transition-colors">
      No notions match your filter.
    </p>
  </div>

  <div class="space-y-12 mb-16" id="notions-list">
    {renderedNotions.map(({ notion, Content }) => (
      <article
        id={notion.slug}
        class="notion-article bg-white dark:bg-slate-800/20 rounded-2xl p-6 md:p-8 border border-slate-200 dark:border-slate-700/50 shadow-sm expandable-container scroll-mt-24 transition-colors"
        data-search={`${notion.data.acronym} ${notion.data.title} ${notion.data.description} ${notion.data.tags.join(' ')}`.toLowerCase()}
      >
        <header class="mb-6 pb-6 border-b border-slate-200 dark:border-slate-700/50 transition-colors">
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
            <div>
              <div class="flex flex-wrap gap-2 mb-3">
                {notion.data.tags.map((tag: string) => (
                  <span class="px-2 py-1 text-xs font-semibold bg-sky-100 dark:bg-accent/10 text-sky-700 dark:text-accent rounded border border-sky-200 dark:border-accent/20 transition-colors">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-2 transition-colors">
                <a href={`/notions/${notion.slug}/`} class="hover:text-sky-600 dark:hover:text-accent transition-colors decoration-transparent text-slate-900 dark:text-slate-100">
                  {notion.data.acronym}
                </a>
              </h2>
              <p class="text-xl text-slate-600 dark:text-slate-400 font-medium transition-colors">
                {notion.data.title}
              </p>
            </div>
            
            <div class="flex flex-col gap-2 min-w-[200px]">
              {notion.data.implies.length > 0 && (
                <div class="text-sm">
                  <span class="text-slate-500 dark:text-slate-500 font-medium mr-2 transition-colors">Implies:</span>
                  <span class="text-slate-700 dark:text-slate-300 transition-colors">{notion.data.implies.join(', ')}</span>
                </div>
              )}
              {notion.data.implied_by.length > 0 && (
                <div class="text-sm">
                  <span class="text-slate-500 dark:text-slate-500 font-medium mr-2 transition-colors">Implied by:</span>
                  <span class="text-slate-700 dark:text-slate-300 transition-colors">{notion.data.implied_by.join(', ')}</span>
                </div>
              )}
            </div>
          </div>
        </header>

        <div class="relative">
          <div class="expandable-content max-h-48 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="prose prose-slate dark:prose-invert prose-a:text-sky-600 dark:prose-a:text-accent hover:prose-a:text-sky-500 dark:hover:prose-a:text-sky-300 max-w-none transition-colors">
              <Content />
            </div>
          </div>
          <div class="gradient-overlay absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white dark:from-slate-900 to-transparent pointer-events-none hidden transition-colors"></div>
        </div>
        
        <button class="expand-btn hidden mt-4 px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 text-sm font-medium rounded-lg transition-colors border border-slate-200 dark:border-slate-600">
          Read Full Definition
        </button>
      </article>
    ))}
  </div>
</BaseLayout>

<script>
  const initializeExpanders = () => {
    const containers = document.querySelectorAll('.expandable-container');
    
    containers.forEach(container => {
      const content = container.querySelector('.expandable-content') as HTMLElement;
      const btn = container.querySelector('.expand-btn') as HTMLButtonElement;
      const overlay = container.querySelector('.gradient-overlay') as HTMLElement;
      
      if (!content || !btn || !overlay) return;

      const toggleContent = () => {
        if (content.classList.contains('max-h-48')) {
          content.classList.remove('max-h-48');
          overlay.classList.add('hidden');
          btn.textContent = 'Show Less';
        } else {
          content.classList.add('max-h-48');
          overlay.classList.remove('hidden');
          btn.textContent = 'Read Full Definition';
        }
      };

      btn.addEventListener('click', toggleContent);

      setTimeout(() => {
        if (content.scrollHeight > content.clientHeight + 10) {
          btn.classList.remove('hidden');
          overlay.classList.remove('hidden');
        } else {
          content.classList.remove('max-h-48');
        }
      }, 100);
    });
  };

  // setTimeout inside ensures scrollHeight is measured after layout
  document.addEventListener('DOMContentLoaded', initializeExpanders);

  const initializeSearch = () => {
    const input = document.getElementById('notion-search') as HTMLInputElement | null;
    const articles = document.querySelectorAll<HTMLElement>('.notion-article');
    const countEl = document.getElementById('search-count');
    const emptyEl = document.getElementById('search-empty');
    const total = articles.length;

    if (!input) return;

    const applyFilter = () => {
      const query = input.value.trim().toLowerCase();
      let visible = 0;

      articles.forEach((article) => {
        const haystack = article.getAttribute('data-search') || '';
        const match = query === '' || haystack.includes(query);
        article.classList.toggle('hidden', !match);
        if (match) visible++;
      });

      if (countEl) countEl.textContent = visible.toString();
      if (emptyEl) emptyEl.classList.toggle('hidden', visible !== 0);
    };

    input.addEventListener('input', applyFilter);

    // If the user arrived with a hash, don't let filtering hide it
    if (window.location.hash) {
      const target = document.getElementById(window.location.hash.slice(1));
      if (target) target.scrollIntoView();
    }
  };

  document.addEventListener('DOMContentLoaded', initializeSearch);
</script>
