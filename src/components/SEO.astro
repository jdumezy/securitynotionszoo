---
interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface DefinedTermInput {
  termCode: string;
  alternateName?: string[];
}

interface Props {
  title: string;
  description: string;
  canonicalURL?: string | URL;
  type?: string;
  image?: string;
  keywords?: string[];
  noindex?: boolean;
  author?: string;
  datePublished?: string;
  dateModified?: string;
  definedTerm?: DefinedTermInput;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description,
  type = 'website',
  image = '/icon.png',
  keywords,
  noindex = false,
  author = 'Jules Dumezy',
  datePublished,
  dateModified,
  definedTerm,
  breadcrumbs,
} = Astro.props;

// Determine canonical URL from Astro.url or props
const canonicalURL = Astro.props.canonicalURL || new URL(Astro.url.pathname, Astro.site || Astro.url);
const canonicalString = canonicalURL.toString();
const resolvedImageWithDomain = new URL(image, Astro.site || Astro.url).toString();

const siteOrigin = (Astro.site?.toString() || `${canonicalURL.origin}/`).replace(/\/+$/, '') + '/';
const isRoot = (Astro.url.pathname || '/') === '/';

const siteDescription = 'A taxonomy of cryptographic security notions, focusing on Fully Homomorphic Encryption (FHE).';

const websiteNode = {
  '@type': 'WebSite',
  '@id': `${siteOrigin}#website`,
  url: siteOrigin,
  name: 'SecurityNotionsZoo',
  alternateName: 'Cryptography Security Notions Taxonomy',
  description: siteDescription,
};

const taxonomySetNode = {
  '@type': 'DefinedTermSet',
  '@id': `${siteOrigin}#taxonomy`,
  name: 'Security Notions Taxonomy',
  url: siteOrigin,
  description: siteDescription,
};

const graph: Record<string, unknown>[] = [websiteNode];
if (isRoot) {
  graph.push(taxonomySetNode);
}

if (definedTerm) {
  const termNode: Record<string, unknown> = {
    '@type': 'DefinedTerm',
    '@id': `${canonicalString}#term`,
    name: definedTerm.termCode,
    termCode: definedTerm.termCode,
    description,
    url: canonicalString,
    inDefinedTermSet: { '@id': `${siteOrigin}#taxonomy` },
  };
  if (definedTerm.alternateName && definedTerm.alternateName.length > 0) {
    termNode.alternateName = definedTerm.alternateName;
  }
  if (datePublished) termNode.dateCreated = datePublished;
  if (dateModified) termNode.dateModified = dateModified;
  if (keywords && keywords.length > 0) termNode.keywords = keywords.join(', ');
  if (author) {
    termNode.author = { '@type': 'Person', name: author };
  }
  graph.push(termNode);
}

if (breadcrumbs && breadcrumbs.length > 0) {
  graph.push({
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((b, i) => {
      const item: Record<string, unknown> = {
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
      };
      if (b.url) item.item = b.url;
      return item;
    }),
  });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" href="/icon.png" />
<link rel="apple-touch-icon" href="/icon.png" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#0ea5e9" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Robots -->
{noindex && <meta name="robots" content="noindex, follow" />}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />
{author && <meta name="author" content={author} />}
{keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedImageWithDomain} />
<meta property="og:site_name" content="SecurityNotionsZoo" />
{datePublished && <meta property="article:published_time" content={datePublished} />}
{dateModified && <meta property="article:modified_time" content={dateModified} />}
{author && <meta property="article:author" content={author} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={resolvedImageWithDomain} />

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
