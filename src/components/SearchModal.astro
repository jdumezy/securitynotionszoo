---
// Global search modal. Included once in BaseLayout.
// Renders a hidden modal + the client JS that wires keyboard shortcuts,
// lazy-fetches the search index, scores results, and handles keyboard
// navigation. The trigger button itself lives inline in BaseLayout.astro
// so it can be positioned inside the existing nav flex.
---

<div
  id="search-modal"
  class="fixed inset-0 z-[60]"
  role="dialog"
  aria-modal="true"
  aria-labelledby="search-modal-label"
  hidden
>
  <div
    id="search-backdrop"
    class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"
  >
  </div>
  <div
    class="relative w-full max-w-2xl mx-auto mt-16 sm:mt-24 px-4 sm:px-0"
  >
    <div
      class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl border border-slate-200 dark:border-slate-800 overflow-hidden"
    >
      <div
        class="flex items-center gap-3 px-4 py-3 border-b border-slate-200 dark:border-slate-800"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-slate-400 dark:text-slate-500 shrink-0"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <label id="search-modal-label" for="search-input" class="sr-only">
          Search the site
        </label>
        <input
          id="search-input"
          type="search"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="Search notions, primer, flavors\u2026"
          class="flex-1 bg-transparent text-base text-slate-900 dark:text-slate-100 placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:outline-none"
        />
        <kbd
          class="hidden sm:inline-flex items-center px-1.5 py-0.5 text-[10px] font-sans font-semibold text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded shrink-0"
        >
          ESC
        </kbd>
      </div>
      <div
        id="search-results"
        class="max-h-[60vh] overflow-y-auto"
      >
      </div>
      <div
        class="flex flex-wrap items-center gap-x-4 gap-y-1 px-4 py-2.5 text-[11px] text-slate-500 dark:text-slate-400 border-t border-slate-200 dark:border-slate-800 bg-slate-50/60 dark:bg-slate-950/40"
      >
        <span class="inline-flex items-center gap-1">
          <kbd
            class="inline-flex items-center px-1.5 py-0.5 font-sans font-semibold bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded"
            >↑</kbd
          >
          <kbd
            class="inline-flex items-center px-1.5 py-0.5 font-sans font-semibold bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded"
            >↓</kbd
          > navigate
        </span>
        <span class="inline-flex items-center gap-1">
          <kbd
            class="inline-flex items-center px-1.5 py-0.5 font-sans font-semibold bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded"
            >↵</kbd
          > select
        </span>
        <span class="inline-flex items-center gap-1">
          <kbd
            class="inline-flex items-center px-1.5 py-0.5 font-sans font-semibold bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded"
            >Esc</kbd
          > close
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  #search-results mark {
    background-color: rgb(254 240 138 / 0.75);
    color: inherit;
    padding: 0 1px;
    border-radius: 2px;
  }
  :global(.dark) #search-results mark {
    background-color: rgb(250 204 21 / 0.25);
    color: rgb(253 224 71);
  }
</style>

<script>
  interface SearchDoc {
    type: "notion" | "primer" | "flavors" | "page";
    id: string;
    url: string;
    title: string;
    subtitle?: string;
    snippet: string;
    body: string;
    tags: string[];
  }

  const TYPE_LABELS: Record<SearchDoc["type"], string> = {
    notion: "Notion",
    primer: "Primer",
    flavors: "Flavors",
    page: "Page",
  };

  const TYPE_CLASSES: Record<SearchDoc["type"], string> = {
    notion:
      "bg-sky-100 text-sky-700 dark:bg-accent/20 dark:text-accent",
    primer:
      "bg-violet-100 text-violet-700 dark:bg-violet-500/15 dark:text-violet-300",
    flavors:
      "bg-amber-100 text-amber-800 dark:bg-amber-500/15 dark:text-amber-300",
    page: "bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300",
  };

  const initSearch = () => {
    const openBtn = document.getElementById(
      "search-open-btn",
    ) as HTMLButtonElement | null;
    const modal = document.getElementById(
      "search-modal",
    ) as HTMLElement | null;
    const backdrop = document.getElementById(
      "search-backdrop",
    ) as HTMLElement | null;
    const input = document.getElementById(
      "search-input",
    ) as HTMLInputElement | null;
    const resultsEl = document.getElementById(
      "search-results",
    ) as HTMLElement | null;
    if (!openBtn || !modal || !backdrop || !input || !resultsEl) return;

    let docs: SearchDoc[] | null = null;
    let docsPromise: Promise<SearchDoc[]> | null = null;
    let results: SearchDoc[] = [];
    let selectedIdx = 0;
    let returnFocus: HTMLElement | null = null;

    const loadIndex = async () => {
      if (docs) return docs;
      if (!docsPromise) {
        docsPromise = fetch("/search-index.json")
          .then((r) => r.json())
          .then((d: { docs: SearchDoc[] }) => d.docs);
      }
      docs = await docsPromise;
      return docs;
    };

    const openModal = async () => {
      returnFocus = document.activeElement as HTMLElement | null;
      modal.hidden = false;
      document.body.style.overflow = "hidden";
      // Focus after the modal is painted so iOS keyboard pops up reliably
      requestAnimationFrame(() => input.focus());
      await loadIndex();
      runSearch();
    };

    const closeModal = () => {
      modal.hidden = true;
      document.body.style.overflow = "";
      input.value = "";
      results = [];
      selectedIdx = 0;
      resultsEl.innerHTML = "";
      if (returnFocus && typeof returnFocus.focus === "function") {
        returnFocus.focus();
      }
    };

    // Simple token-based scorer. Returns top 15 docs.
    const scoreDocs = (query: string): SearchDoc[] => {
      if (!docs) return [];
      const tokens = query
        .toLowerCase()
        .split(/\s+/)
        .map((t) => t.trim())
        .filter(Boolean);
      if (!tokens.length) return [];

      const scored: Array<{ doc: SearchDoc; score: number }> = [];
      for (const doc of docs) {
        const title = doc.title.toLowerCase();
        const subtitle = (doc.subtitle || "").toLowerCase();
        const snippet = doc.snippet.toLowerCase();
        const body = doc.body.toLowerCase();
        const tagsStr = doc.tags.join(" ").toLowerCase();
        const haystack = `${title} ${subtitle} ${snippet} ${body} ${tagsStr}`;

        // Require every token to appear somewhere
        if (!tokens.every((t) => haystack.includes(t))) continue;

        let score = 0;
        for (const t of tokens) {
          if (title === t) score += 250;
          else if (title.startsWith(t)) score += 140;
          else if (title.includes(t)) score += 90;
          if (subtitle.includes(t)) score += 45;
          if (tagsStr.includes(t)) score += 30;
          if (snippet.includes(t)) score += 20;
          // Body matches contribute less, but a token found only in the
          // body is still relevant (the `every` gate already filtered).
          if (body.includes(t)) score += 5;
        }
        // Slight boost for notion type: probably what the user wants most
        if (doc.type === "notion") score += 10;

        if (score > 0) scored.push({ doc, score });
      }

      scored.sort((a, b) => b.score - a.score);
      return scored.slice(0, 15).map((s) => s.doc);
    };

    const escapeHtml = (s: string) =>
      s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const escapeRegex = (s: string) =>
      s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

    // Highlight matches with <mark>, using a placeholder trick so we can
    // still HTML-escape the text safely.
    const MARK_OPEN = "\u0001MK\u0001";
    const MARK_CLOSE = "\u0002MK\u0002";
    const highlight = (text: string, tokens: string[]) => {
      let out = text;
      for (const t of tokens) {
        if (!t) continue;
        const re = new RegExp(`(${escapeRegex(t)})`, "gi");
        out = out.replace(re, `${MARK_OPEN}$1${MARK_CLOSE}`);
      }
      out = escapeHtml(out);
      out = out.split(MARK_OPEN).join("<mark>").split(MARK_CLOSE).join("</mark>");
      return out;
    };

    const renderResults = () => {
      const query = input.value.trim();
      resultsEl.innerHTML = "";
      if (!query) {
        resultsEl.innerHTML =
          '<div class="px-4 py-10 text-center text-sm text-slate-500 dark:text-slate-400">Start typing to search notions, primer sections, flavors, and pages.</div>';
        return;
      }
      if (results.length === 0) {
        resultsEl.innerHTML = `<div class="px-4 py-10 text-center text-sm text-slate-500 dark:text-slate-400">No matches for <span class="font-semibold text-slate-700 dark:text-slate-200">${escapeHtml(query)}</span></div>`;
        return;
      }
      const tokens = query.toLowerCase().split(/\s+/).filter(Boolean);
      results.forEach((doc, idx) => {
        const a = document.createElement("a");
        a.href = doc.url;
        a.dataset.idx = String(idx);
        a.className =
          "search-result flex items-start gap-3 px-4 py-3 border-b border-slate-100 dark:border-slate-800/70 transition-colors cursor-pointer no-underline decoration-transparent";
        const selected = idx === selectedIdx;
        if (selected) {
          a.classList.add("bg-sky-50", "dark:bg-accent/10");
        }
        const subtitleHtml = doc.subtitle
          ? `<div class="text-xs text-slate-500 dark:text-slate-400 truncate">${highlight(doc.subtitle, tokens)}</div>`
          : "";
        a.innerHTML = `
          <span class="inline-flex items-center shrink-0 px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide mt-0.5 ${TYPE_CLASSES[doc.type]}">${TYPE_LABELS[doc.type]}</span>
          <div class="min-w-0 flex-1">
            <div class="text-sm font-semibold text-slate-900 dark:text-slate-100 truncate">${highlight(doc.title, tokens)}</div>
            ${subtitleHtml}
            <div class="text-xs text-slate-600 dark:text-slate-400 line-clamp-2 mt-0.5">${highlight(doc.snippet, tokens)}</div>
          </div>
        `;
        a.addEventListener("mouseenter", () => {
          selectedIdx = idx;
          refreshSelection();
        });
        a.addEventListener("click", (e) => {
          e.preventDefault();
          navigateTo(doc.url);
        });
        resultsEl.appendChild(a);
      });
    };

    const refreshSelection = () => {
      const all = resultsEl.querySelectorAll<HTMLAnchorElement>(".search-result");
      all.forEach((el, i) => {
        if (i === selectedIdx) {
          el.classList.add("bg-sky-50", "dark:bg-accent/10");
          el.scrollIntoView({ block: "nearest" });
        } else {
          el.classList.remove("bg-sky-50", "dark:bg-accent/10");
        }
      });
    };

    const navigateTo = (url: string) => {
      closeModal();
      window.location.href = url;
    };

    const runSearch = () => {
      results = scoreDocs(input.value);
      selectedIdx = 0;
      renderResults();
    };

    // ---- Wire events ----
    openBtn.addEventListener("click", () => {
      openModal();
    });
    backdrop.addEventListener("click", () => {
      closeModal();
    });

    input.addEventListener("input", () => {
      runSearch();
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        if (results.length === 0) return;
        selectedIdx = (selectedIdx + 1) % results.length;
        refreshSelection();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (results.length === 0) return;
        selectedIdx = (selectedIdx - 1 + results.length) % results.length;
        refreshSelection();
      } else if (e.key === "Enter") {
        if (results.length > 0) {
          e.preventDefault();
          navigateTo(results[selectedIdx].url);
        }
      }
    });

    // Global keyboard shortcuts
    window.addEventListener("keydown", (e) => {
      const target = e.target as HTMLElement | null;
      const inEditable =
        target &&
        (target.tagName === "INPUT" ||
          target.tagName === "TEXTAREA" ||
          (target as HTMLElement).isContentEditable);

      // Cmd+K / Ctrl+K: open from anywhere
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
        e.preventDefault();
        if (modal.hidden) openModal();
        else closeModal();
        return;
      }

      // "/": open only when not typing in a form field
      if (e.key === "/" && !inEditable && modal.hidden) {
        e.preventDefault();
        openModal();
        return;
      }

      // Escape: close if open
      if (e.key === "Escape" && !modal.hidden) {
        e.preventDefault();
        closeModal();
      }
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSearch);
  } else {
    initSearch();
  }
</script>
