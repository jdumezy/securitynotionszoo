---
import type { CollectionEntry } from 'astro:content';

interface Props {
  notions: CollectionEntry<'notions'>[];
}

const { notions } = Astro.props;

// Generate Mermaid syntax dynamically
let mermaidGraph = 'graph TD;\n';

notions.forEach(notion => {
  const acronym = notion.data.acronym;
  // Node definition (click to go to page)
  mermaidGraph += `  ${acronym}["${acronym}"]\n`;
  mermaidGraph += `  click ${acronym} "/notions/${notion.slug}" "Go to ${acronym}"\n`;
  
  // Implies relationships (A --> B)
  if (notion.data.implies && notion.data.implies.length > 0) {
    notion.data.implies.forEach(target => {
      mermaidGraph += `  ${acronym} --> ${target}\n`;
    });
  }
});
---

<div class="mermaid-container w-full overflow-x-auto flex justify-center py-4 bg-transparent min-h-[300px] flex items-center" data-mermaid={mermaidGraph}>
</div>

<script>
  import mermaid from 'mermaid';
  
  const getMermaidConfig = (theme: string) => {
    const isDark = theme === 'dark';
    return {
      startOnLoad: false,
      theme: 'base',
      securityLevel: 'loose',
      fontFamily: 'inherit',
      themeVariables: isDark ? {
        darkMode: true,
        background: 'transparent',
        primaryColor: '#1e293b',
        primaryTextColor: '#f8fafc',
        primaryBorderColor: '#475569',
        lineColor: '#64748b',
        secondaryColor: '#334155',
        tertiaryColor: '#0f172a'
      } : {
        darkMode: false,
        background: 'transparent',
        primaryColor: '#ffffff',
        primaryTextColor: '#0f172a',
        primaryBorderColor: '#cbd5e1',
        lineColor: '#94a3b8',
        secondaryColor: '#f1f5f9',
        tertiaryColor: '#f8fafc'
      }
    };
  };

  const renderGraphs = async () => {
    const isDark = document.documentElement.classList.contains('dark');
    const theme = isDark ? 'dark' : 'light';
    
    mermaid.initialize(getMermaidConfig(theme) as any);
    
    const containers = document.querySelectorAll('.mermaid-container');
    for (const container of containers) {
      const code = container.getAttribute('data-mermaid');
      if (code) {
        const id = 'mermaid-' + Math.random().toString(36).substr(2, 9);
        try {
          const { svg } = await mermaid.render(id, code);
          container.innerHTML = svg;
        } catch (e) {
          console.error('Mermaid rendering failed', e);
        }
      }
    }
  };

  // Render initially: module scripts are deferred, so DOM is likely ready.
  // We use readyState to handle both normal loads and HMR/race conditions.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderGraphs);
  } else {
    renderGraphs();
  }
  
  // Re-render when theme changes
  document.addEventListener('theme-changed', renderGraphs);
</script>
